OPENAI_API_KEY= # Replace with your OpenAI API key
ANTHROPIC_API_KEY= # Replace with your Anthropic API key if needed
OLLAMA= # Replace with your Ollama configuration if needed
PROMPT_TOOLKIT_NO_CPR=1 # Set to 1 to disable CPR, leave empty or set to 0 otherwise

# Metasploit MCP server
MSF_PASSWORD=yourpassword # Password for the Metasploit RPC server
MSF_SERVER=127.0.0.1 # Address msfrpcd listens on inside the metasploit-mcp container
MSF_PORT=55553 # Port for the Metasploit RPC server
MSF_SSL=false # Set to true if msfrpcd is started with SSL enabled